	(text_box "Choose Kind = 0.2\nVout = 12V\nEstimate ~4W of power\nSpec Iout_max = 350mA\nExpect D = 0.6\nEstimate efficiency eta = 85%\nEstimate V_{in, min} = 4.5V\nV_{d} = 580mV\n\nI_{in, DC} = (P_{out}) / (eta * V_{in, min})\nI_{in, DC} = 4W / (0.85 * 4.5V)\nI_{in, DC} = 1.04A\n\n(Nominal case)\nL_{min} >= Vin / (I_(in, DC} * K_ind) * D / f_{sw}\nL_{min} >= 5V / (1.04A * 0.2) * 0.6 / 600kHz\nL_{min} >= 23.81uH\n\n(Worst case D = 0.5)\nL_{min} >= (V_{out} + V_d) / (I_{in, DC} * K_ind) * 1 / (4 * f_{sw})\nL_{min} >= (12V + 580mV) / (1.04A * 0.2) * 1 / (4 * 600kHz)\nL_{min} >= 24.96uH"
		(exclude_from_sim no)
		(at 15.24 76.2 0)
